+-+def append_trade_session_snapshot(
+-+    store: JsonStateStore,
+-+    user_id: int,
+-+    *,
+-+    pending: PendingIntent,
+-+    extraction: ScreenshotExtraction,
+-+    analysis: dict[str, Any],
+-+    caption: str = "",
+-+    now: datetime | None = None,
+-+    user_timezone: str = "America/Los_Angeles",
+-+) -> dict[str, Any]:
+-+    now = now or datetime.now(timezone.utc)
+-+    session = ensure_trade_session(store, user_id, pending)
+-+    snapshots = session.setdefault("snapshots", [])
+-+    if not isinstance(snapshots, list):
+-+        snapshots = []
+-+        session["snapshots"] = snapshots
+-+    snapshots.append(
+-+        {
+-+            "received_at_utc": now.isoformat(timespec="seconds"),
+-+            "caption": caption,
+-+            "screen_type": extraction.screen_type,
+-+            "extraction": extraction.model_dump(),
+-+            "analysis": deepcopy(analysis),
+-+        }
+-+    )
+-+    # Keep enough context for CALL/PUT/graph comparisons without preserving stale clutter.
+-+    session["snapshots"] = snapshots[-10:]
+-+    session["updated_at_utc"] = now.isoformat(timespec="seconds")
+-+    result = judge_trade_session(session, now=now, user_timezone=user_timezone)
+-+    session["last_result"] = deepcopy(result)
+-+
+-+    user = store.user(user_id)
+-+    user["trade_session"] = session
+-+    user["last_analysis"] = deepcopy(result)
+-+    user["last_full_reason"] = clean_text(result.get("why_full"), "")
+-+    # A TRADING session remains open for more screenshots until CANCEL or CONFIRM.
+-+    user["pending_intent"] = asdict(pending)
+-+    store.update_user(user_id, user)
+-+    return result
