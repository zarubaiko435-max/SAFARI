+-+def _visible_tickers(extraction: ScreenshotExtraction) -> set[str]:
+-+    tickers = {
+-+        clean_text(extraction.ticker_header.value, "").upper(),
+-+        *{clean_text(row.ticker, "").upper() for row in extraction.option_rows},
+-+        *{clean_text(position.ticker, "").upper() for position in extraction.positions},
+-+    }
+-+    tickers.discard("")
+-+    return tickers
+-+
