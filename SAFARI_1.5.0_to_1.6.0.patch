+def start_trade_session(store: JsonStateStore, user_id: int, pending: PendingIntent) -> dict[str, Any]:
+    if pending.mode != "TRADING":
+        raise ValueError("Trade session requires TRADING pending intent")
+    session = {
+        "session_id": f"{pending.ticker or 'UNKNOWN'}-{pending.instrument}-{pending.created_at_utc}",
+        "ticker": (pending.ticker or "").upper(),
+        "instrument": pending.instrument,
+        "started_at_utc": pending.created_at_utc,
+        "expires_at_utc": pending.expires_at_utc,
+        "status": "collecting",
+        "snapshots": [],
+        "last_result": None,
+    }
+    user = store.user(user_id)
+    user["pending_intent"] = asdict(pending)
+    user["trade_session"] = session
+    store.update_user(user_id, user)
+    return deepcopy(session)
+
+
+def ensure_trade_session(store: JsonStateStore, user_id: int, pending: PendingIntent) -> dict[str, Any]:
+    user = store.user(user_id)
+    raw = user.get("trade_session")
+    if isinstance(raw, dict):
+        same = (
+            clean_text(raw.get("ticker"), "").upper() == clean_text(pending.ticker, "").upper()
+            and clean_text(raw.get("instrument"), "UNKNOWN").upper() == pending.instrument
+            and clean_text(raw.get("status"), "collecting") == "collecting"
+        )
+        if same:
+            return deepcopy(raw)
+    return start_trade_session(store, user_id, pending)
+
+
+def clear_trade_session(store: JsonStateStore, user_id: int) -> None:
+    user = store.user(user_id)
+    user["trade_session"] = None
+    user["pending_intent"] = None
+    store.update_user(user_id, user)
+
+
+def append_trade_session_snapshot(
+    store: JsonStateStore,
+    user_id: int,
+    *,
+    pending: PendingIntent,
+    extraction: ScreenshotExtraction,
+    analysis: dict[str, Any],
+    caption: str = "",
+    now: datetime | None = None,
+    user_timezone: str = "America/Los_Angeles",
+) -> dict[str, Any]:
+    now = now or datetime.now(timezone.utc)
+    session = ensure_trade_session(store, user_id, pending)
+    snapshots = session.setdefault("snapshots", [])
+    if not isinstance(snapshots, list):
+        snapshots = []
+        session["snapshots"] = snapshots
+    snapshots.append(
+        {
+            "received_at_utc": now.isoformat(timespec="seconds"),
+            "caption": caption,
+            "screen_type": extraction.screen_type,
+            "extraction": extraction.model_dump(),
+            "analysis": deepcopy(analysis),
+        }
+    )
+    # Keep enough context for CALL/PUT/graph comparisons without preserving stale clutter.
+    session["snapshots"] = snapshots[-10:]
+    session["updated_at_utc"] = now.isoformat(timespec="seconds")
+    result = judge_trade_session(session, now=now, user_timezone=user_timezone)
+    session["last_result"] = deepcopy(result)
+
+    user = store.user(user_id)
+    user["trade_session"] = session
+    user["last_analysis"] = deepcopy(result)
+    user["last_full_reason"] = clean_text(result.get("why_full"), "")
+    # A TRADING session remains open for more screenshots until CANCEL or CONFIRM.
+    user["pending_intent"] = asdict(pending)
+    store.update_user(user_id, user)
+    return result
+
+
+def confirm_trade_session(store: JsonStateStore, user_id: int) -> dict[str, Any] | None:
+    user = store.user(user_id)
+    session = user.get("trade_session")
+    if not isinstance(session, dict):
+        return None
+    result = session.get("last_result")
+    if not isinstance(result, dict):
+        return None
+    confirmed = {
+        "confirmed_at_utc": utc_now(),
+        "session_id": session.get("session_id"),
+        "ticker": session.get("ticker"),
+        "instrument": session.get("instrument"),
+        "result": deepcopy(result),
+    }
+    ideas = user.setdefault("confirmed_trade_ideas", [])
+    if not isinstance(ideas, list):
+        ideas = []
+        user["confirmed_trade_ideas"] = ideas
+    ideas.append(confirmed)
+    del ideas[:-20]
+    session["status"] = "confirmed"
+    session["confirmed_at_utc"] = confirmed["confirmed_at_utc"]
+    user["trade_session"] = session
+    user["pending_intent"] = None
+    store.update_user(user_id, user)
+    return deepcopy(result)
+
