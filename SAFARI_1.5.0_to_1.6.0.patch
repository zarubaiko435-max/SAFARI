 # ---------------------------------------------------------------------------
+# Multi-screenshot TRADING session judge
+# ---------------------------------------------------------------------------
+
+
+def _session_reference_date(now: datetime, user_timezone: str) -> date:
+    try:
+        return now.astimezone(ZoneInfo(user_timezone)).date()
+    except Exception:
+        return now.date()
+
+
+def _snapshot_extraction(snapshot: dict[str, Any]) -> ScreenshotExtraction | None:
+    raw = snapshot.get("extraction")
+    if not isinstance(raw, dict):
+        return None
+    try:
+        return ScreenshotExtraction.model_validate(raw)
+    except Exception:
+        return None
+
+
+def _visible_tickers(extraction: ScreenshotExtraction) -> set[str]:
+    tickers = {
+        clean_text(extraction.ticker_header.value, "").upper(),
+        *{clean_text(row.ticker, "").upper() for row in extraction.option_rows},
+        *{clean_text(position.ticker, "").upper() for position in extraction.positions},
+    }
+    tickers.discard("")
+    return tickers
+
+
+def _chart_direction(chart: ChartExtraction) -> tuple[str, str]:
+    """Return UP/DOWN/SIDEWAYS/UNKNOWN using only visible numeric facts."""
+    change = safe_float(chart.period_change_percent.value)
+    evidence = ""
+    if change is not None:
+        evidence = f"видима зміна {change:+.2f}%"
+    else:
+        open_price = safe_float(chart.open_price.value)
+        close_price = safe_float(chart.close_price.value)
+        if open_price and close_price is not None:
+            change = (close_price - open_price) / open_price * 100
+            evidence = f"видимі Open/Close дають {change:+.2f}%"
+
+    if change is None:
+        return "UNKNOWN", "На графіку немає надійної числової зміни або Open/Close."
+    if change >= 0.25:
+        return "UP", evidence
+    if change <= -0.25:
+        return "DOWN", evidence
+    return "SIDEWAYS", evidence
+
+
+def _option_row_completeness(row: OptionRow) -> int:
+    fields = [
+        row.strike,
+        row.expiration,
+        row.bid,
+        row.ask,
+        row.open_interest if row.open_interest.label_visible else ExtractedField(),
+        row.volume if row.volume.label_visible else ExtractedField(),
+        row.iv,
+        row.delta,
+        row.theta,
+    ]
+    return sum(1 for field in fields if field_present(field))
+
+
+def _session_score_bar(value: Any) -> str:
+    score = safe_float(value)
+    normalized = max(0, min(5, int(round(score or 0))))
+    return "■" * normalized + "□" * (5 - normalized)
+
+
+def judge_trade_session(
+    session: dict[str, Any],
+    *,
+    now: datetime | None = None,
+    user_timezone: str = "America/Los_Angeles",
+) -> dict[str, Any]:
+    """Judge all screenshots in one idea as a single deterministic evidence set."""
+    now = now or datetime.now(timezone.utc)
+    reference = _session_reference_date(now, user_timezone)
+    ticker = clean_text(session.get("ticker"), "").upper()
+    instrument = clean_text(session.get("instrument"), "UNKNOWN").upper()
+    if instrument not in {"CALL", "PUT"}:
+        instrument = "UNKNOWN"
+
+    snapshots = session.get("snapshots")
+    if not isinstance(snapshots, list):
+        snapshots = []
+
+    contract_versions: dict[str, tuple[int, OptionRow, dict[str, Any], ScreenshotExtraction]] = {}
+    opposite_contracts = 0
+    chart_candidates: list[tuple[int, dict[str, Any], ScreenshotExtraction]] = []
+    ticker_conflicts: list[str] = []
+
+    for index, snapshot in enumerate(snapshots):
+        if not isinstance(snapshot, dict):
+            continue
+        extraction = _snapshot_extraction(snapshot)
+        if extraction is None:
+            continue
+        visible_tickers = _visible_tickers(extraction)
+        if ticker and visible_tickers and ticker not in visible_tickers:
+            ticker_conflicts.append(
+                f"Скрін #{index + 1}: очікується {ticker}, видно {', '.join(sorted(visible_tickers))}."
+            )
+            continue
+        if extraction.screen_type == "chart":
+            chart_candidates.append((index, snapshot, extraction))
+        for row in extraction.option_rows:
+            row_ticker = clean_text(row.ticker, "").upper() or clean_text(
+                extraction.ticker_header.value, ""
+            ).upper()
+            if ticker and row_ticker and row_ticker != ticker:
+                continue
+            if row.instrument != instrument:
+                if row.instrument in {"CALL", "PUT"}:
+                    opposite_contracts += 1
+                continue
+            if not row.ticker and ticker:
+                row = row.model_copy(update={"ticker": ticker})
+            key = (
+                f"{row.instrument}|{canonical_strike(row.strike.value)}|"
+                f"{canonical_expiration(row.expiration.value, reference=reference)}"
+            )
+            contract_versions[key] = (index, row, snapshot, extraction)
+
+    selected_tuple: tuple[int, OptionRow, dict[str, Any], ScreenshotExtraction] | None = None
+    if contract_versions:
+        versions = list(contract_versions.values())
+        preferred, _ = select_option_candidate([item[1] for item in versions], instrument, reference=reference)
+        if preferred is not None:
+            selected_tuple = next((item for item in versions if item[1] is preferred), None)
+        if selected_tuple is None:
+            selected_tuple = max(
+                versions,
+                key=lambda item: (_option_row_completeness(item[1]), item[0]),
+            )
+
+    latest_chart = max(chart_candidates, key=lambda item: item[0]) if chart_candidates else None
+    chart_direction = "UNKNOWN"
+    chart_evidence = "Графік не надіслано."
+    chart_freshness = "unconfirmed"
+    if latest_chart:
+        _, chart_snapshot, chart_extraction = latest_chart
+        chart_direction, chart_evidence = _chart_direction(chart_extraction.chart)
+        chart_analysis = chart_snapshot.get("analysis")
+        if isinstance(chart_analysis, dict):
+            chart_freshness = clean_text(chart_analysis.get("data_freshness"), "unconfirmed")
+
+    hard_stops: list[dict[str, str]] = []
+    missing: list[str] = []
+    dte: int | None = None
+    spread_pct: float | None = None
+    strike_text = "—"
+    expiration_text = "—"
+    premium_text = "—"
+    selected_freshness = "unconfirmed"
+    selected_quality = "low"
+    selected_row: OptionRow | None = None
+
+    if selected_tuple:
+        _, selected_row, selected_snapshot, selected_extraction = selected_tuple
+        selected_analysis = selected_snapshot.get("analysis")
+        if isinstance(selected_analysis, dict):
+            selected_freshness = clean_text(selected_analysis.get("data_freshness"), "unconfirmed")
+            selected_quality = clean_text(selected_analysis.get("data_quality"), "low")
+        spread_stop, spread_pct = spread_policy(selected_row.bid.value, selected_row.ask.value)
+        liquidity_stop = liquidity_policy(selected_row.open_interest, selected_row.volume)
+        expiration_stop, dte = expiration_policy(selected_row.expiration.value, reference=reference)
+        earnings_stop = earnings_policy(selected_extraction.earnings_date, dte, reference=reference)
+        freshness_stop = stop(
+            "stale_data",
+            "clear" if selected_freshness in {"confirmed_current", "user_confirmed"} else "triggered",
+            "Контракт підтверджено як актуальний."
+            if selected_freshness in {"confirmed_current", "user_confirmed"}
+            else "Актуальність контракту не підтверджена.",
+        )
+        conflict_stop = stop(
+            "conflicting_data",
+            "triggered" if ticker_conflicts else "clear",
+            "; ".join(ticker_conflicts) if ticker_conflicts else "Тикер у сесії узгоджений.",
+        )
+        hard_stops = [
+            spread_stop,
+            liquidity_stop,
+            expiration_stop,
